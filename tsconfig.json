{
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      // Alias principal
      "@/*": ["./src/*"],
      
      // Componentes
      "@/components/*": ["./src/components/*"],
      "@/ui/*": ["./src/components/ui/*"],
      "@/features/*": ["./src/components/features/*"],
      "@/shared/*": ["./src/components/shared/*"],
      "@/providers/*": ["./src/components/providers/*"],
      
      // Hooks
      "@/hooks/*": ["./src/hooks/*"],
      
      // Lib
      "@/lib/*": ["./src/lib/*"],
      "@/utils/*": ["./src/lib/utils/*"],
      "@/api/*": ["./src/lib/api/*"],
      "@/config/*": ["./src/lib/config/*"],
      "@/types/*": ["./src/lib/types/*"],
      
      // Estilos
      "@/styles/*": ["./src/styles/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.js",
    "**/*.jsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase"
  ]
}