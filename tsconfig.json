{
  "compilerOptions": {
    "removeComments": true,
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/ui/*": ["./src/components/ui/*"],
      "@/features/*": ["./src/features/*"],
      "@/providers/*": ["./src/providers/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/utils/*": ["./src/lib/utils/*"],
      "@/api/*": ["./src/lib/api/*"],
      "@/config/*": ["./src/lib/config/*"],
      "@/types/*": ["./src/lib/api/types/*"],
      "@/styles/*": ["./src/style/*"],
      "@/style/*": ["./src/style/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.js",
    "**/*.jsx",
    ".next/dev/types/**/*.ts",
    "src/lib/api/client/db.js"
  ],
  "exclude": ["node_modules", "supabase", "src-tauri"]
}